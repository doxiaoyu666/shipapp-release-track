{
  "name": "@shipapp/release-track",
  "version": "0.1.0",
  "description": "Post-release tracking dashboard — crash signatures, downloads, and version health for iOS apps.",
  "main": "dist/cli.js",
  "bin": {
    "shipapp-release-track": "dist/cli.js",
    "shipapp-release-track-mcp": "dist/mcp.js"
  },
  "scripts": {
    "build": "npm run build:dashboard && npm run build:server",
    "build:server": "esbuild src/cli.ts --bundle --platform=node --target=node18 --outfile=dist/cli.js --format=cjs --external:better-sqlite3 && esbuild src/mcp/server.ts --bundle --platform=node --target=node18 --outfile=dist/mcp.js --format=cjs --external:better-sqlite3",
    "build:dashboard": "cd src/dashboard && npx vite build --outDir ../../dist/dashboard-public",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": ["ios", "release", "crash", "analytics", "dashboard", "app-store"],
  "author": "",
  "license": "MIT",
  "engines": { "node": ">=18" },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "jsonwebtoken": "^9.0.0",
    "open": "^8.4.2",
    "ora": "^5.4.1",
    "yargs": "^17.7.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/yargs": "^17.0.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
